--- !u!114 &308557658
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 308557656}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 14702f5f74daa1741aaedcf82ac86627, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ReaderEffectIntro
  textUI: {fileID: 308557659}
  fullText: "Trong nhi\u1EC1u th\u1EBF k\u1EF7, v\xF9ng \u0111\u1EA5t ph\xEDa nam
    c\u1EE7a v\u01B0\u01A1ng qu\u1ED1c t\u1EEBng l\xE0 n\u01A1i tr\xF9 ph\xFA, n\u01A1i
    s\u1EF1 s\u1ED1ng sinh s\xF4i d\u01B0\u1EDBi \xE1nh m\u1EB7t tr\u1EDDi \u1EA5m
    \xE1p. Nh\u01B0ng t\u1EA5t c\u1EA3 \u0111\xE3 thay \u0111\u1ED5i k\u1EC3 t\u1EEB
    khi m\u1ED9t l\u1EDDi nguy\u1EC1n c\u1ED5 \u0111\u1EA1i b\u1ECB \u0111\xE1nh
    th\u1EE9c. B\xF3ng t\u1ED1i len l\u1ECFi v\xE0o t\u1EEBng c\xE1nh r\u1EEBng,
    t\u1EEBng d\xF2ng s\xF4ng, b\xF3p m\xE9o m\u1ECDi sinh v\u1EADt s\u1ED1ng th\xE0nh
    nh\u1EEFng h\xECnh h\xE0i d\u1ECB d\u1EA1ng v\xE0 hung t\u1EE3n.  Nh\u1EEFng
    ng\xF4i l\xE0ng b\u1ECB b\u1ECF hoang. Ti\u1EBFng g\xE0o th\xE9t vang l\xEAn
    gi\u1EEFa m\xE0n \u0111\xEAm. V\xE0 gi\u1EDD \u0111\xE2y, v\xF9ng \u0111\u1EA5t
    \u1EA5y kh\xF4ng c\xF2n l\xE0 m\u1ED9t ph\u1EA7n c\u1EE7a v\u01B0\u01A1ng qu\u1ED1c\u2014m\xE0
    l\xE0 m\u1ED9t v\u1EBFt th\u01B0\u01A1ng \u0111ang d\u1EA7n lan r\u1ED9ng.  Tr\u01B0\u1EDBc
    hi\u1EC3m h\u1ECDa \u0111ang c\u1EADn k\u1EC1, nh\xE0 vua \u0111\xE3 tri\u1EC7u
    h\u1ED3i hi\u1EC7p s\u0129 xu\u1EA5t s\u1EAFc nh\u1EA5t c\u1EE7a m\xECnh.  Ng\u01B0\u01A1i. 
    Mang theo thanh ki\u1EBFm v\xE0 l\xF2ng d\u0169ng c\u1EA3m, ng\u01B0\u01A1i \u0111\u01B0\u1EE3c
    giao tr\u1ECDng tr\xE1ch ti\u1EBFn v\xE0o v\xF9ng \u0111\u1EA5t b\u1ECB nguy\u1EC1n
    r\u1EE7a\u2014kh\xE1m ph\xE1 ngu\u1ED3n g\u1ED1c c\u1EE7a b\xF3ng t\u1ED1i, ti\xEAu
    di\u1EC7t nh\u1EEFng sinh v\u1EADt gh\xEA r\u1EE3n, v\xE0 \u0111\u1ED1i m\u1EB7t
    v\u1EDBi k\u1EBB \u0111\u1EE9ng sau t\u1EA5t c\u1EA3.  B\u1EDFi ch\u1EC9 khi
    k\u1EBB gieo r\u1EAFc l\u1EDDi nguy\u1EC1n b\u1ECB \u0111\xE1nh b\u1EA1i\u2026 
    \xC1nh s\xE1ng m\u1EDBi c\xF3 th\u1EC3 tr\u1EDF l\u1EA1i."
  delayBetweenChars: 0.01
